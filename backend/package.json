{
  "name": "codeguardian-backend",
  "version": "1.0.0",
  "description": "CodeGuardian AI Backend - Express API with IBM Bob MCP Integration",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "ai",
    "code-analysis",
    "security",
    "modernization",
    "mcp"
  ],
  "author": "CodeGuardian AI Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.2",
    "multer": "^1.4.5-lts.1",
    "adm-zip": "^0.5.16",
    "simple-git": "^3.27.0",
    "uuid": "^11.0.5",
    "winston": "^3.17.0",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.12",
    "@types/adm-zip": "^0.5.7",
    "@types/uuid": "^10.0.0",
    "@types/node": "^22.16.5",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.32.0",
    "prettier": "^3.7.3",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}